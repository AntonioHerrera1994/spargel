---
import '../styles/navbar.css'
import Logo from '../assets/spargel-logo.png'
---

<nav class="navbar" id="navbar">
  <div class="navbar-container">
    <a href="/" class="navbar-logo">
      <img
        src={Logo.src}
        alt="Spargel logo"/>
    </a>

    <button class="navbar-toggle" id="navbarToggle" aria-label="Menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <ul class="navbar-menu" id="navbarMenu">
      <li><a href="/en/#about">About Us</a></li>
      <li><a href="/en/#process">Process</a></li>
      <li><a href="/recipes">Recipes</a></li>
      <li><a href="/en/#contact">Contact</a></li>
      <li><a href="/en/#quote" class="btn-pedir">Request a Quote</a></li>
      <li class="navbar-lang">
        <a href="/" aria-label="Cambiar a Español">
          <svg viewBox="0 0 24 16" class="flag-icon" role="img" aria-hidden="true">
            <rect width="8" height="16" fill="#006341" />
            <rect x="8" width="8" height="16" fill="#fff" />
            <rect x="16" width="8" height="16" fill="#CE1126" />
            <circle cx="12" cy="8" r="2.3" fill="#8B5A2B" />
            <path d="M12 6.1c.6.4.9 1.1.7 1.9-.1.7-.6 1.2-1.2 1.4.3-.5.4-1.1.2-1.7-.1-.6-.5-1.1-1-1.4.4-.2.9-.3 1.3-.2z" fill="#4a3520" />
          </svg>
          <span>ES</span>
        </a>
      </li>
      <li class="navbar-socials">
        <a href="#" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
          </svg>
        </a>
        <a href="#" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
          </svg>
        </a>
        <a href="#" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
    import '../scripts/navbar'
</script>