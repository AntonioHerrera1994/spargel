---
// Footer.astro
import "../styles/footer.css";

const navLinks = [
  { label: "Nuestro Origen", href: "#origen" },
  { label: "Sustentabilidad", href: "#sustentabilidad" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Contacto", href: "#contacto" },
];

const infoLinks = [
  { label: "Aviso de Privacidad", href: "/aviso-de-privacidad" },
  { label: "Términos y Condiciones", href: "/terminos-y-condiciones" },
  { label: "Logística Global", href: "/logistica-global" },
];

import FooterLogo from '../assets/footer-logo.png'
---

<footer class="footer">
  <div class="footer__top">
    <div class="footer__brand">
      <div class="footer__logo">
      <img 
      src={FooterLogo.src}
      alt="spargel footer logo"
      width="160px"
      />
      </div>
      <p class="footer__desc">
        Líderes en el cultivo sustentable de espárragos en el noroeste de
        México. Calidad de exportación con alma bajacaliforniana.
      </p>
    </div>

    <nav class="footer__col" aria-label="Navegación">
      <h3 class="footer__col-title">NAVEGACIÓN</h3>
      <ul class="footer__links">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Información">
      <h3 class="footer__col-title">INFORMACIÓN</h3>
      <ul class="footer__links">
        {
          infoLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="footer__divider"></div>

  <div class="footer__bottom">
    <p class="footer__copyright">
      © <span id="footer-year">2024</span> Spargel de los Planes. Todos los
      derechos reservados.
    </p>

    <div class="footer__social">
      <a href="https://www.facebook.com/p/Spargel-de-los-Planes-100086761817706/" class="footer__social-link" target="_blank" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
          </svg>
      </a>
      <a href="https://www.instagram.com/spargeldelosplanes/"  target="_blank" class="footer__social-link" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
        </svg>
      </a>
      <a href="https://wa.link/fzev4z" class="footer__social-link" target="_blank" aria-label="Compartir">
       <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
      </a>
    </div>
  </div>
</footer>

<script src="../scripts/footer.js"></script>