---
// ContactSection.astro
import "../styles/contacto.css";

const contactInfo = [
  {
    icon: "mail",
    label: "Correo Electrónico",
    value: "contacto@spargeldelosplanes.com",
  },
  {
    icon: "phone",
    label: "Llámanos",
    value: "(612) 155-0691",
  },
  {
    icon: "pin",
    label: "Ubicación",
    value: "Los Planes, BCS, México",
  },
];
---

<section class="contact" id="contacto">
  <div class="contact__grid">
    <!-- Columna izquierda -->
    <div class="contact__intro">
      <h2 class="contact__title">Hablemos de Calidad</h2>
      <p class="contact__text">
        Estamos listos para abastecer su negocio con el mejor producto de la
        región. Envíenos un mensaje para recibir nuestra tabla de cotización
        para mayoreo.
      </p>

      <ul class="contact__list">
        {
          contactInfo.map((item) => (
            <li class="contact__item">
              <span class="contact__icon">
                {item.icon === "mail" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="m2 6 10 7 10-7" />
                  </svg>
                )}
                {item.icon === "phone" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z" />
                  </svg>
                )}
                {item.icon === "pin" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
              </span>
              <span class="contact__item-text">
                <span class="contact__item-label">{item.label}</span>
                <span class="contact__item-value">{item.value}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Columna derecha: formulario -->
    <div class="contact__card">
      <form id="contact-form" class="contact-form" novalidate>
        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="cf-name">Nombre</label>
            <input type="text" id="cf-name" name="name" placeholder="Su nombre" autocomplete="name" />
            <span class="contact-form__error" data-error-for="cf-name"></span>
          </div>
          <div class="contact-form__field">
            <label for="cf-company">Empresa</label>
            <input type="text" id="cf-company" name="company" placeholder="Nombre de su empresa" autocomplete="organization" />
            <span class="contact-form__error" data-error-for="cf-company"></span>
          </div>
        </div>

        <div class="contact-form__field">
          <label for="cf-email">Correo Electrónico</label>
          <input type="email" id="cf-email" name="email" placeholder="email@ejemplo.com" autocomplete="email" />
          <span class="contact-form__error" data-error-for="cf-email"></span>
        </div>

        <div class="contact-form__field">
          <label for="cf-message">Mensaje</label>
          <textarea id="cf-message" name="message" rows="5" placeholder="Cuéntanos cómo podemos ayudarte"></textarea>
          <span class="contact-form__error" data-error-for="cf-message"></span>
        </div>

        <button type="submit" class="contact-form__submit">
          <span class="contact-form__submit-label">Enviar Mensaje</span>
        </button>

        <p class="contact-form__status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script src="../scripts/contacto.js"></script>