---
import { getCollection } from "astro:content";
import "../styles/recetas.css";
 
const allRecipes = await getCollection("recipes", ({ data }) => !data.draft);
 
const recipes = allRecipes
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3); // solo las 3 más recientes en el home
---

<section class="recipes">
  <div class="recipes__header">
    <div class="recipes__eyebrow">
      <span class="recipes__eyebrow-line"></span>
      GASTRONOMY
      <span class="recipes__eyebrow-line"></span>
    </div>
    <h2 class="recipes__title">From Field to Table</h2>
    <p class="recipes__subtitle">
      Get inspired by the unique flavor of our asparagus in gourmet dishes.
    </p>
  </div>

  <div class="recipes__grid">
    {
      recipes.map((recipe) => (
        <a href={`/recipes/${recipe.id}`} class="recipe-card">
          <div class="recipe-card__image">
            <img src={recipe.data.image} alt={recipe.data.title} loading="lazy" />
          </div>
          <div class="recipe-card__body">
            <h3 class="recipe-card__title">{recipe.data.title}</h3>
            <p class="recipe-card__text">{recipe.data.description}</p>
            <span class="recipe-card__link">
              View Recipe <span class="recipe-card__arrow" aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))
    }
  </div>

  <div class="recipes__cta" style="margin-top: 50px;">
    <a href="/recipes" class="recipes__cta-link">View all recipes →</a>
  </div>
</section>

<script src="../scripts/recetas.js"></script>