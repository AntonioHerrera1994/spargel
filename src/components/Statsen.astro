---
import "../styles/stats.css";
const stats = [
  { value: 15, suffix: "+", label: "Hectares", sublabel: "Protected Farmland" },
  { value: 100, suffix: "%", label: "Sustainable", sublabel: "Solar Energy" },
  { value: 10, suffix: "+", label: "Years", sublabel: "In the Market" },
];
---

<section class="stats">
  <div class="stats__card">
    {
      stats.map((stat, index) => (
        <div class="stats__item">
          <p class="stats__value">
            <span class="stats__number" data-target={stat.value}>0</span>{stat.suffix}
            {" "}{stat.label}
          </p>
          <p class="stats__sublabel">{stat.sublabel}</p>
        </div>
      ))
    }
  </div>
</section>

<script src="../scripts/stats.js"></script>