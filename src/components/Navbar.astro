---
import '../styles/navbar.css'
import Logo from '../assets/spargel-logo.png'
---

<nav class="navbar" id="navbar">
  <div class="navbar-container">
    <a href="/" class="navbar-logo">
      <!-- Puedes reemplazar el emoji por tu logo real -->
   <img 
                src={Logo.src}
        
                alt="spargel-logo"/>
    </a>
 
    <button class="navbar-toggle" id="navbarToggle" aria-label="Menú">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
 
    <ul class="navbar-menu" id="navbarMenu">
      <li><a href="/#nosotros">Nosotros</a></li>
      <li><a href="/#proceso">Proceso</a></li>
      <li><a href="/recetas">Recetas</a></li>
      <li><a href="/#contacto">Contacto</a></li>
      <li><a href="#pedir" class="btn-pedir">Cotizar Pedido</a></li>
      <li class="navbar-lang">
        <a href="/en" aria-label="Switch to English">
          <svg viewBox="0 0 24 16" class="flag-icon" role="img" aria-hidden="true">
            <rect width="24" height="16" fill="#B22234" />
            <g fill="#fff">
              <rect y="1.23" width="24" height="1.23" />
              <rect y="3.69" width="24" height="1.23" />
              <rect y="6.15" width="24" height="1.23" />
              <rect y="8.61" width="24" height="1.23" />
              <rect y="11.08" width="24" height="1.23" />
              <rect y="13.54" width="24" height="1.23" />
            </g>
            <rect width="10" height="8.6" fill="#3C3B6E" />
            <g fill="#fff">
              <circle cx="1.5" cy="1.5" r="0.5" />
              <circle cx="4" cy="1.5" r="0.5" />
              <circle cx="6.5" cy="1.5" r="0.5" />
              <circle cx="1.5" cy="3.5" r="0.5" />
              <circle cx="4" cy="3.5" r="0.5" />
              <circle cx="6.5" cy="3.5" r="0.5" />
              <circle cx="1.5" cy="5.5" r="0.5" />
              <circle cx="4" cy="5.5" r="0.5" />
              <circle cx="6.5" cy="5.5" r="0.5" />
              <circle cx="1.5" cy="7.5" r="0.5" />
              <circle cx="4" cy="7.5" r="0.5" />
              <circle cx="6.5" cy="7.5" r="0.5" />
            </g>
          </svg>
          <span>EN</span>
        </a>
      </li>
      <li class="navbar-socials">
        <a href="https://www.instagram.com/spargeldelosplanes/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
          </svg>
        </a>
        <a href="https://www.facebook.com/p/Spargel-de-los-Planes-100086761817706/" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
          </svg>
        </a>
        <a href="https://wa.link/fzev4z" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
    import '../scripts/navbar'
</script>