---
import Layout from "../layouts/Layout.astro";
import "../styles/noencontrada.css";
---

<Layout title="Página no encontrada — Spargel de los Planes">
  <section class="notfound">
    <div class="notfound__content">
      <div class="notfound__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2v13" />
          <path d="M12 22c-3-1-5-3.5-5-6.5C7 12 9 10 12 9c3 1 5 3 5 6.5 0 3-2 5.5-5 6.5Z" />
          <path d="M9 6c1-1 2-1 3-1s2 0 3 1" />
          <path d="M8.5 9.5C9.5 8.3 10.7 8 12 8s2.5.3 3.5 1.5" />
        </svg>
      </div>

      <p class="notfound__eyebrow">ERROR 404</p>

      <h1 class="notfound__title">Esta página se cosechó antes de tiempo</h1>

      <p class="notfound__text">
        No encontramos lo que buscabas — puede que la página haya sido
        movida o ya no exista. Mientras tanto, seguimos cultivando lo mejor
        del Valle de Los Planes para ti.
      </p>

      <div class="notfound__actions">
        <a href="/" class="notfound__btn notfound__btn--solid">
          Volver al Inicio
        </a>
        <button type="button" class="notfound__btn notfound__btn--outline" id="notfound-back">
          ← Regresar
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
    const backBtn = document.getElementById("notfound-back");

if (backBtn) {
  backBtn.addEventListener("click", () => {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      window.location.href = "/";
    }
  });
}
</script>